==== examples/error_arity.c ===


int main() {
    // Correct
    /* 1, 2 */
    /* 10 */
/* transformer(10)*/ int a;
    // Error: Too few
    /* myMacro(1)*/
    // Error: Too many
    /* myMacro(1, 2, 3)*/
    // Error: Transformer with wrong count
    /* transformer*/ int b;
    /* transformer(1, 2)*/ int c;
    return 0;
}


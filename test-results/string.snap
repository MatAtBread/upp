==== examples/string/main.c ===
/* A minimal C stdio/stdlib/string for upp to make it easy to
   see the output of the examples but permit compilation
*/
extern int puts(const char *s);
extern int printf(const char *format, ...);
extern int fputs(const char *s, void *stream);
extern void *malloc(unsigned long n);
extern void free(void *p);
extern char *strcpy(char *dest, const char *src);
extern char *strncat(char *dest, const char *src, unsigned long n);
extern int strcmp(const char *s1, const char *s2);
extern int snprintf(char *str, unsigned long size, const char *format, ...);
extern unsigned long strlen(const char *s);
extern void *stderr;
extern void *_stderr;

#include "strings.h"
#include "overload.h"
 String _int_method_String(int n) {
    String s = _Managed_allocate(_Managed_Sizeof_String(16));


    snprintf(s->data, 16, "%d", n);
    /* elided retain/release s */return s;
}
 String _float_method_String(float n) {
    String s = _Managed_allocate(_Managed_Sizeof_String(16));


    snprintf(s->data, 16, "%f", n);
    /* elided retain/release s */return s;
}
 String _char_method_String(char *s) {
    return String_literal(s);
}
/* overload*/ String toString_char_ptr(char *s) { return String_literal(s); }
/* overload*/ String toString_int(int n) { return _int_method_String(n); }
int main() {
    String a = toString_int(789);

    String b = toString_char_ptr("from char *");

    String s = String_literal("abcd");

    String t = _String_method_copy(s);

    _Managed_retain(t);String u = t;

    printf("s: %s [%d]\n", s->data, _String_method_managed_reference_count(s));
    printf("t: %s [%d]\n", t->data, _String_method_managed_reference_count(t));
    printf("u: %s [%d]\n", u->data, _String_method_managed_reference_count(u));
    int i = 123;
    String n = _int_method_String(i);

    printf("n: %s [%d]\n", n->data, _String_method_managed_reference_count(n));
    float f = 4.56;
    String m = _float_method_String(f);

    printf("m: %s [%d]\n", m->data, _String_method_managed_reference_count(m));
    char *psz = "text";
    printf("%s\n",_char_method_String(psz)->data);
    printf("%s\n",String_literal("literal")->data);
    printf("%s\n",a->data);
    printf("%s\n",b->data);
    














_Managed_release(&m);
_Managed_release(&n);
_Managed_release(&u);
_Managed_release(&t);
_Managed_release(&s);
_Managed_release(&b);
_Managed_release(&a);return 0;
}

==== examples/string/strings.c ===
/*implements:String*/
#include "strings.h"

#include <string.h>
String String_literal(const char *src) {
    int _n = strlen(src);
    String s = _Managed_allocate(_Managed_Sizeof_String(_n + 1));


 // Size includes null terminator
    strcpy(s->data, src);
    _Managed_retain(s);/* elided retain/release s */
_Managed_release(&s);return s;
}
 String _String_method_copy(String s) { 
        _Managed_retain(s); 
         
        /* elided retain/release s */
_Managed_release(&s);return String_literal(s->data);
        }
 int _String_method_length(String s) { 
        _Managed_retain(s); 
         
        /* elided retain/release s */
_Managed_release(&s);return strlen(s->data);
        }

==== examples/string/strings.h ===
#include "managed-struct.h"
#include "std/package.h"

#ifndef __MANAGED_STRUCT__HUP
#define  __MANAGED_STRUCT__HUP
struct _ReferenceCount {
  int ref_count;
};
static inline void *_Managed_allocate(int size) {
  struct _ReferenceCount *p = malloc(size + sizeof(struct _ReferenceCount));
  p->ref_count = 1;
  // printf("{%d} Allocate %d bytes\n", p->ref_count, size);
  return (void *)(p + 1);
}
static inline void *_Managed_retain(void *data) {
  struct _ReferenceCount *p = (struct _ReferenceCount *)data - 1;
  p->ref_count++;
  return data;
}
static inline void _Managed_release(void *__p) {
  void **_p = (void **)__p;
  void *data = *_p;
  if (data) {
    struct _ReferenceCount *p = (struct _ReferenceCount *)data - 1;
    if (--p->ref_count <= 0) {
      // printf("{%d} Free\n", p->ref_count);
      free(p);
      *_p = ((void *)0);
    }
  }
}
static inline void *_Managed_set(void *_dest, void *_src) {
  void **dest = _dest;
  if (*dest) { 
    struct _ReferenceCount *p = (struct _ReferenceCount *)(*dest) - 1;
    _Managed_release(dest);
  }
  return *dest = (_src ? _Managed_retain(_src) : ((void *)0));
}
static inline void *_Managed_move(void *_dest, void *_src) {
  void **dest = _dest;
  if (*dest) { 
    struct _ReferenceCount *p = (struct _ReferenceCount *)(*dest) - 1;
    _Managed_release(dest);
  }
  return *dest = _src;
}
static inline int _Managed_ref_count(void *data) {
    if (!data) return -1;
    return ((struct _ReferenceCount *)data - 1)->ref_count;
}
#endif
// __MANAGED_STRUCT__HUP
typedef struct {
    char data[];
}* String;
#define _Managed_Sizeof_String(n) (sizeof(*(String)0) + sizeof(((String)0)->data[0]) * (n))

static inline  int _String_method_managed_reference_count(String p) { 
         
         
        /* elided retain/release p */return _Managed_ref_count((void *)p);
        }

 

extern String String_literal(const char *src);
extern String _String_method_copy(String s);
extern int _String_method_length(String s);

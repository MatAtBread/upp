#include "io-lite.h"

@include(method.hup)

typedef struct { int x; } Point;

@method(Point)
void setX(Point *p, int v) { p->x = v; }

@method(Point)
int getX(Point *p) { return p->x; }

int main() {
    Point p = {10};
    p.setX(20);
    int val = p.getX();
    printf("%d\n", val);
    return 0;
}
